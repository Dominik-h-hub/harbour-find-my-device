[Desktop Entry]
Type=Application
X-Nemo-Application-Type=silica-qt5
Icon=harbour-find-my-device
Exec=sailfish-qml harbour-find-my-device
Name=Radar
Name[de]=Radar

[X-Sailjail]
# Sandboxed with a minimal permission set (shown to the user on first launch):
#   Internet     - MQTT, map tiles
#   Location     - geoclue GPS fix, read location.conf
#   Audio        - ringtone preview in Settings
#   FindMyDevice - app-specific (sailjail/FindMyDevice.permission): shared DB
#                  with the daemons, daemon start/stop, priv-helper spool
# The background daemons are systemd services and run outside this sandbox.
OrganizationName=harbour-find-my-device
ApplicationName=harbour-find-my-device
Permissions=Internet;Location;Audio;FindMyDevice