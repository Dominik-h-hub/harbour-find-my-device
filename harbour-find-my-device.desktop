[Desktop Entry]
Type=Application
X-Nemo-Application-Type=silica-qt5
Icon=harbour-find-my-device
Exec=sailfish-qml harbour-find-my-device
Name=Radar
Name[de]=Radar

[X-Sailjail]
# Sailjail sandboxing is disabled. The GUI needs accesses that stock Sailjail
# permissions cannot express, and running sandboxed proved unstable:
#   - shared SQLite DB with the (unsandboxed) systemd user daemons
#   - start/stop of those daemons (org.freedesktop.systemd1)
#   - request spool of the privileged root helper (/run/harbour-find-my-device)
# Stock permissions that would otherwise apply: Internet (MQTT, map tiles),
# Location (geoclue GPS fix), Audio (ringtone preview).
Sandboxing=Disabled